# ============================================================
# BergLabs – Supabase Edge Function secrets
#
# Local development:  copy to supabase/.env and run `supabase start`
# Production:         set with `supabase secrets set --env-file supabase/.env`
#
# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by the Supabase platform – do not set them here.
# ============================================================

# Anthropic API key (https://console.anthropic.com) – used by
# generate-listing and analyze-images.
ANTHROPIC_API_KEY=sk-ant-...

# Public URL of the frontend – used for invite email redirect URLs.
APP_URL=http://localhost:3000

# Google OAuth (only needed if you enable Google sign-in locally;
# in production these are configured in the Supabase Dashboard instead)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
