# ============================================================
# BergLabs – Supabase Edge Function secrets
#
# Local development:  copy to supabase/.env and run `supabase start`
# Production:         set with `supabase secrets set --env-file supabase/.env`
#
# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by the Supabase platform – do not set them here.
# ============================================================

# Anthropic API key (https://console.anthropic.com) – used by
# generate-listing and analyze-images.
ANTHROPIC_API_KEY=sk-ant-...

# Stripe secret key (Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (created when you add the webhook endpoint,
# see README section "Stripe")
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for the per-seat subscription
# (500 SEK/agent/month incl. VAT, recurring, licensed quantity)
STRIPE_PRICE_ID=price_...

# Public URL of the frontend – used for Stripe Checkout success/cancel URLs
# and the Customer Portal return URL.
APP_URL=http://localhost:3000

# Google OAuth (only needed if you enable Google sign-in locally;
# in production these are configured in the Supabase Dashboard instead)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
