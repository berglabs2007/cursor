# ============================================================
# BergLabs – Next.js frontend environment variables
# Copy to .env.local and fill in the values.
# ============================================================

# From Supabase Dashboard > Project Settings > API
# (create the project in an EU region, e.g. Frankfurt eu-central-1)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Public site URL (used for auth redirects). Locally: http://localhost:3000
# In production: your Vercel domain, e.g. https://berglabs.se
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe publishable key (safe to expose). From Stripe Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
